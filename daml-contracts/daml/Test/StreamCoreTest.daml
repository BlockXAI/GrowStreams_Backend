-- Test 9: Stream Factory ID Increment
testFactoryIdIncrement : Script ()
testFactoryIdIncrement = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  charlie <- allocateParty "Charlie"
  
  factory <- submit admin do
    createCmd StreamFactory with
      admin = admin
      nextStreamId = 1
      users = [alice, bob, charlie]
  
  let startTime = time (date 2026 Mar 11) 0 0 0
  
  -- Create first stream (ID should be 1)
  stream1 <- submit alice do
    exerciseCmd factory CreateStream with
      sender = alice
      receiver = bob
      flowRate = 0.1
      initialDeposit = 100.0
      currentTime = startTime
  
  Some s1 <- queryContractId alice stream1
  assertMsg "First stream should have ID 1" (s1.streamId == 1)
  
  -- Create second stream (ID should be 2)
  stream2 <- submit alice do
    exerciseCmd factory CreateStream with
      sender = alice
      receiver = charlie
      flowRate = 0.2
      initialDeposit = 200.0
      currentTime = startTime
  
  Some s2 <- queryContractId alice stream2
  assertMsg "Second stream should have ID 2" (s2.streamId == 2)
  
  return ()

-- Test 10: Edge Case - Zero Accrual When Paused
testZeroAccrualWhenPaused : Script ()
testZeroAccrualWhenPaused = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  
  factory <- submit admin do
    createCmd StreamFactory with
      admin = admin
      nextStreamId = 1
      users = [alice, bob]
  
  let startTime = time (date 2026 Mar 11) 0 0 0
  stream <- submit alice do
    exerciseCmd factory CreateStream with
      sender = alice
      receiver = bob
      flowRate = 0.1
      initialDeposit = 100.0
      currentTime = startTime
  
  -- Immediately pause
  pausedStream <- submit alice do
    exerciseCmd stream Pause with
      currentTime = startTime
  
  -- Wait 1000 seconds while paused
  let queryTime = addRelTime startTime (seconds 1000)
  
  -- Query withdrawable (should be 0)
  withdrawable <- submit bob do
    exerciseCmd pausedStream GetWithdrawable with
      currentTime = queryTime
  
  assertMsg "Should have 0 GROW withdrawable when paused" (withdrawable == 0.0)
  
  return ()

-- Test 11: Edge Case - No Withdrawal When Nothing Accrued
testNoWithdrawalWhenZero : Script ()
testNoWithdrawalWhenZero = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  
  factory <- submit admin do
    createCmd StreamFactory with
      admin = admin
      nextStreamId = 1
      users = [alice, bob]
  
  let startTime = time (date 2026 Mar 11) 0 0 0
  stream <- submit alice do
    exerciseCmd factory CreateStream with
      sender = alice
      receiver = bob
      flowRate = 0.1
      initialDeposit = 100.0
      currentTime = startTime
  
  -- Try to withdraw immediately (0 seconds elapsed)
  submitMustFail bob do
    exerciseCmd stream Withdraw with
      currentTime = startTime
  
  return ()

-- Test 12: Edge Case - Cannot Pause Already Paused Stream
testCannotPausePaused : Script ()
testCannotPausePaused = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  
  factory <- submit admin do
    createCmd StreamFactory with
      admin = admin
      nextStreamId = 1
      users = [alice, bob]
  
  let startTime = time (date 2026 Mar 11) 0 0 0
  stream <- submit alice do
    exerciseCmd factory CreateStream with
      sender = alice
      receiver = bob
      flowRate = 0.1
      initialDeposit = 100.0
      currentTime = startTime
  
  -- Pause stream
  pausedStream <- submit alice do
    exerciseCmd stream Pause with
      currentTime = startTime
  
  -- Try to pause again (should fail)
  submitMustFail alice do
    exerciseCmd pausedStream Pause with
      currentTime = startTime
  
  return ()

