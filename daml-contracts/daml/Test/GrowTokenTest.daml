  return ()

-- Test 13: Edge Case - Split Equal to Total
testSplitEqualTotal : Script ()
testSplitEqualTotal = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  
  faucet <- submit admin do
    createCmd Faucet with admin = admin
  
  aliceToken <- submit admin do
    exerciseCmd faucet Mint with
      recipient = alice
      amount = 100.0
  
  -- Try to split equal to total (should fail)
  submitMustFail alice do
    exerciseCmd aliceToken Split with
      splitAmount = 100.0
  
  return ()

-- Test 14: Edge Case - Merge Different Owners
testMergeDifferentOwners : Script ()
testMergeDifferentOwners = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  
  faucet <- submit admin do
    createCmd Faucet with admin = admin
  
  aliceToken <- submit admin do
    exerciseCmd faucet Mint with
      recipient = alice
      amount = 100.0
  
  bobToken <- submit admin do
    exerciseCmd faucet Mint with
      recipient = bob
      amount = 200.0
  
  -- Try to merge tokens with different owners (should fail)
  submitMustFail alice do
    exerciseCmd aliceToken Merge with
      otherCid = bobToken
  
  return ()

-- Test 15: Edge Case - Exceed Allowance
testExceedAllowance : Script ()
testExceedAllowance = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  vault <- allocateParty "Vault"
  
  faucet <- submit admin do
    createCmd Faucet with admin = admin
  
  aliceToken <- submit admin do
    exerciseCmd faucet Mint with
      recipient = alice
      amount = 1000.0
  
  allowance <- submit alice do
    exerciseCmd aliceToken Approve with
      spender = vault
      allowanceAmount = 100.0
  
  -- Try to transfer more than allowance (should fail)
  submitMustFail vault do
    exerciseCmd allowance TransferFrom with
      transferAmount = 200.0
      recipient = vault
  
  return ()
